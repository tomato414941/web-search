# Coolify staging environment variables
# Do not commit real secrets.

ENVIRONMENT=production
COMPOSE_PROFILES=

POSTGRES_PASSWORD=change-me-strong
POSTGRES_MAX_CONNECTIONS=64
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_MEM_LIMIT=768m

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-long-random

ALLOWED_HOSTS=stg-search.example.com
ANALYTICS_SALT=change-me-random

INDEXER_API_KEY=change-me-random
OPENAI_API_KEY=
OPENSEARCH_ENABLED=false

DB_POOL_MIN_FRONTEND=1
DB_POOL_MIN_INDEXER=1
DB_POOL_MIN_INDEXER_WORKER=1
DB_POOL_MIN_INDEXER_MAINTENANCE=1
DB_POOL_MIN_CRAWLER=1

DB_POOL_MAX_FRONTEND=4
DB_POOL_MAX_INDEXER=6
DB_POOL_MAX_INDEXER_WORKER=8
DB_POOL_MAX_INDEXER_MAINTENANCE=2
DB_POOL_MAX_CRAWLER=4

FRONTEND_MEM_LIMIT=384m
INDEXER_MEM_LIMIT=384m
INDEXER_WORKER_MEM_LIMIT=768m
INDEXER_MAINTENANCE_MEM_LIMIT=256m
CRAWLER_MEM_LIMIT=384m

CRAWL_CONCURRENCY=2
CRAWL_AUTO_START=false

INDEXER_JOB_WORKERS=1
INDEXER_JOB_BATCH_SIZE=10
INDEXER_JOB_CONCURRENCY=2
INDEXER_JOB_LEASE_SEC=120
INDEXER_JOB_MAX_RETRIES=5
INDEXER_JOB_POLL_INTERVAL_MS=500
INDEXER_JOB_RETRY_BASE_SEC=5
INDEXER_JOB_RETRY_MAX_SEC=1800
