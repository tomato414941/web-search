# Environment: production, development, or test
# Use development for local runs; docker compose can override to production.
ENVIRONMENT=development
COMPOSE_PROFILES=

# PostgreSQL password (used in docker-compose)
POSTGRES_PASSWORD=websearch_password
POSTGRES_MAX_CONNECTIONS=64
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_MEM_LIMIT=768m

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
ADMIN_SESSION_SECRET=your-session-secret

# Service URLs (local dev)
CRAWLER_SERVICE_URL=http://localhost:8082
INDEXER_SERVICE_URL=http://localhost:8081
INDEXER_API_URL=http://localhost:8081/api/v1/indexer/page

# API Keys
INDEXER_API_KEY=your-indexer-api-key
OPENAI_API_KEY=your-openai-api-key
OPENSEARCH_ENABLED=false
WORKER_METRICS_PORT=9000
QUEUE_METRICS_INTERVAL_SEC=5

# Indexer async job worker
INDEXER_JOB_WORKERS=1
INDEXER_JOB_BATCH_SIZE=10
INDEXER_JOB_CONCURRENCY=2
INDEXER_JOB_LEASE_SEC=120
INDEXER_JOB_MAX_RETRIES=5
INDEXER_JOB_POLL_INTERVAL_MS=500
INDEXER_JOB_RETRY_BASE_SEC=5
INDEXER_JOB_RETRY_MAX_SEC=1800

# Optional crawler runtime (used only with COMPOSE_PROFILES=crawler)
CRAWL_CONCURRENCY=2
CRAWL_AUTO_START=false

# Optional DB pool tuning for docker-compose
DB_POOL_MIN_FRONTEND=1
DB_POOL_MIN_INDEXER=1
DB_POOL_MIN_INDEXER_WORKER=1
DB_POOL_MIN_INDEXER_MAINTENANCE=1
DB_POOL_MIN_CRAWLER=1

DB_POOL_MAX_FRONTEND=4
DB_POOL_MAX_INDEXER=6
DB_POOL_MAX_INDEXER_WORKER=8
DB_POOL_MAX_INDEXER_MAINTENANCE=2
DB_POOL_MAX_CRAWLER=4

# Optional container memory caps for docker-compose
FRONTEND_MEM_LIMIT=384m
INDEXER_MEM_LIMIT=384m
INDEXER_WORKER_MEM_LIMIT=768m
INDEXER_MAINTENANCE_MEM_LIMIT=256m
CRAWLER_MEM_LIMIT=384m
PROMETHEUS_MEM_LIMIT=256m
GRAFANA_MEM_LIMIT=256m

# Optional monitoring profile
PROMETHEUS_BIND_ADDRESS=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=7d
GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin-change-me

# Security
ALLOWED_HOSTS=localhost,127.0.0.1

# Analytics (optional; enables stable session hashing)
ANALYTICS_SALT=
