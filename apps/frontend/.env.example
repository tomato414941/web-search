# Frontend service environment variables
# Copy this file to .env only for local service-level runs.

# Server settings
HOST=0.0.0.0
PORT=8080
WEB_CONCURRENCY=1

# Internal service URLs
CRAWLER_SERVICE_URL=http://crawler:8000
INDEXER_SERVICE_URL=http://indexer:8000

# Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
INDEXER_API_KEY=

# Optional external APIs
OPENAI_API_KEY=

# Host validation
ALLOWED_HOSTS=localhost,127.0.0.1
