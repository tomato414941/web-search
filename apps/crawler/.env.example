# Crawler service environment variables
# Copy this file to .env only for local service-level runs.

# Internal indexer API
INDEXER_API_URL=http://indexer:8000/api/v1/indexer/page

# Shared service API key
INDEXER_API_KEY=

# Optional crawler tuning
CRAWL_CONCURRENCY=2
CRAWL_AUTO_START=false
CRAWL_TIMEOUT_SEC=30
USER_AGENT=PaleBlueSearchBot/1.0
